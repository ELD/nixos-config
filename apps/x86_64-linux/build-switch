#!/usr/bin/env bash
set -euo pipefail

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

HOST=""
OTHER_ARGS=()

while [ $# -gt 0 ]; do
  case "$1" in
    --host=*)
      HOST="${1#*=}"
      shift
      ;;
    --host)
      HOST="$2"
      shift 2
      ;;
    *)
      OTHER_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -z "$HOST" ]]; then
  echo -e "${RED}A host is required.${NC}"
  echo "Usage: nix run '.#build-switch' -- --host HOST_NAME"
  exit 1
fi

FLAKE_TARGET="${HOST}@x86_64-linux"
echo -e "${YELLOW}Building for named host: ${FLAKE_TARGET}${NC}"

echo -e "${YELLOW}Starting...${NC}"

# We pass SSH from user to root so root can download secrets from our private Github
sudo SSH_AUTH_SOCK="$SSH_AUTH_SOCK" /run/current-system/sw/bin/nixos-rebuild switch --flake ".#${FLAKE_TARGET}" "${OTHER_ARGS[@]}"

echo -e "${GREEN}Switch to new generation complete!${NC}"
